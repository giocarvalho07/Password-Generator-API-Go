{
  "info": {
    "name": "Password Generator API",
    "description": "API for generating and validating secure passwords",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Generate Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"length\": 16,\n  \"use_uppercase\": true,\n  \"use_lowercase\": true,\n  \"use_numbers\": true,\n  \"use_symbols\": true\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/password/generate",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "password", "generate"]
        }
      },
      "response": []
    },
    {
      "name": "Validate Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"password\": \"xH7@kL9#mP2&\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/password/validate",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "password", "validate"]
        }
      },
      "response": []
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "protocol": "http",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "localhost:8080",
      "type": "string"
    }
  ]
}